# Database
DATABASE_URL=postgresql://ucp:ucp@localhost:5432/ucp

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3000

# Security — generate with: openssl rand -hex 32
SECRET_KEY=change_me_to_a_secure_random_string_at_least_32_chars

# Runtime
NODE_ENV=development

# Logging (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info
