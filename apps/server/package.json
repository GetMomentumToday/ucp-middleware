{
  "name": "@ucp-middleware/server",
  "version": "0.1.0",
  "private": true,
  "description": "UCP Middleware HTTP server — Fastify application",
  "license": "BSL-1.1",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --watch --experimental-transform-types src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@ucp-middleware/adapters": "*",
    "@ucp-middleware/core": "*",
    "fastify": "^4.27.0",
    "@fastify/sensible": "^5.6.0",
    "pino": "^9.2.0",
    "drizzle-orm": "^0.30.0",
    "postgres": "^3.4.0",
    "ioredis": "^5.4.0",
    "bullmq": "^5.12.0",
    "zod": "^3.23.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.21.0",
    "typescript": "*"
  }
}
